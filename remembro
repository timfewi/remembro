#!/usr/bin/env bash

set -euo pipefail

# Dependencies check
if ! command -v jq &> /dev/null; then
    echo "Error: 'jq' is not installed." >&2
    exit 1
fi

# Define data path
DATA_DIR="$HOME/.remembro"
DATA="$DATA_DIR/data.json"

# Initialize
mkdir -p "$DATA_DIR"
[ ! -f "$DATA" ] && echo '{"commands": []}' > "$DATA"

usage() {
    cat <<EOF
Usage: remembro [options] [args]

Options:
  -l, --list             List all saved commands
  -t, --tree             List commands categorized
  -a, --add NAME CMD CAT Add a command (default category: general)
  -e, --edit             Edit the data file directly
  -d, --delete NAME      Delete a command by name
  -h, --help             Show this help message

Search: remembro [query]
EOF
}

# Helper to execute jq with error handling
run_jq() {
    if ! jq "$@" "$DATA" > "$DATA.tmp"; then
        echo "Error: jq operation failed." >&2
        rm -f "$DATA.tmp"
        exit 1
    fi
    mv "$DATA.tmp" "$DATA"
}

list_cmds() {
    jq -r '.commands[] | "\(.name): \(.cmd) [\(.category)]"' "$DATA"
}

add_cmd() {
    local name="${1:-}" cmd="${2:-}" cat="${3:-general}"
    if [[ -z "$name" || -z "$cmd" ]]; then
        echo "Error: Missing name or command." >&2
        usage
        exit 1
    fi
    
    # Simple sanitization
    name=$(echo "$name" | tr -dc '[:alnum:]-_')
    
    run_jq --arg n "$name" --arg c "$cmd" --arg cat "$cat" \
       '.commands += [{"name": $n, "cmd": $c, "category": $cat}]'
}

delete_cmd() {
    local name="${1:-}"
    if [[ -z "$name" ]]; then
        echo "Error: Missing name to delete." >&2
        exit 1
    fi
    
    run_jq --arg n "$name" '.commands |= map(select(.name != $n))'
}

search_cmd() {
    local query="$1"
    jq -r --arg q "$query" '.commands[] | select(.name | contains($q)) | "\(.name): \(.cmd)"' "$DATA"
}

case "${1:-}" in
    -l|--list) list_cmds ;;
    -t|--tree) jq -r 'group_by(.category)[] | "\(.[0].category)\n  \(.[].name): \(.cmd)"' "$DATA" ;;
    -a|--add) add_cmd "$2" "$3" "$4" ;;
    -d|--delete) delete_cmd "$2" ;;
    -e|--edit) ${EDITOR:-vi} "$DATA" ;;
    -h|--help|help) usage ;;
    *) if [ -n "${1:-}" ]; then search_cmd "$1"; else usage; fi ;;
esac
