#!/usr/bin/env bash

set -euo pipefail

# Dependencies check
if ! command -v jq &> /dev/null; then
    echo "Error: 'jq' is not installed." >&2
    exit 1
fi

# Define data path
DATA_DIR="$HOME/.remembro"
DATA="$DATA_DIR/data.json"

# Initialize
mkdir -p "$DATA_DIR"
[ ! -f "$DATA" ] && echo '{"commands": []}' > "$DATA"

if [[ -t 1 && "${NO_COLOR:-}" == "" ]]; then
    BOLD=$'\033[1m'
    DIM=$'\033[2m'
    CYAN=$'\033[36m'
    GREEN=$'\033[32m'
    YELLOW=$'\033[33m'
    RESET=$'\033[0m'
else
    BOLD=""
    DIM=""
    CYAN=""
    GREEN=""
    YELLOW=""
    RESET=""
fi

usage() {
    cat <<EOF
Usage: remembro [options] [args]

Options:
  -l, --list             List all saved commands
  -t, --tree             List commands categorized
  -a, --add NAME CMD CAT Add a command (default category: general)
  -e, --edit             Edit the data file directly
  -d, --delete NAME      Delete a command by name
  -h, --help             Show this help message

Search: remembro [query]
EOF
}

# Helper to execute jq with error handling
run_jq() {
    if ! jq "$@" "$DATA" > "$DATA.tmp"; then
        echo "Error: jq operation failed." >&2
        rm -f "$DATA.tmp"
        exit 1
    fi
    mv "$DATA.tmp" "$DATA"
}

render_cmds() {
    jq -r \
        --arg bold "$BOLD" \
        --arg dim "$DIM" \
        --arg cyan "$CYAN" \
        --arg green "$GREEN" \
        --arg yellow "$YELLOW" \
        --arg reset "$RESET" \
        '
        def field($key): .[$key] // "";
        def tags:
          if (.tags // []) | length > 0 then
            " " + $dim + "#" + ((.tags // []) | join(" #")) + $reset
          else "" end;
        def notes:
          if field("notes") != "" then
            "\n    " + $dim + "Note: " + field("notes") + $reset
          else "" end;
        .commands
        | sort_by(.category // "general", .name // "")
        | group_by(.category // "general")
        | .[]
        | ($bold + $yellow + "== " + (.[0].category // "general") + " ==" + $reset),
          (.[] |
            "  " + $bold + $green + (.name // "unnamed") + $reset + tags + "\n" +
            "    " + $cyan + (.cmd // "") + $reset +
            (if field("description") != "" then "\n    " + field("description") else "" end) +
            notes
          )
        ' "$DATA"
}

list_cmds() {
    render_cmds
}

add_cmd() {
    local name="${1:-}" cmd="${2:-}" cat="${3:-general}"
    if [[ -z "$name" || -z "$cmd" ]]; then
        echo "Error: Missing name or command." >&2
        usage
        exit 1
    fi
    
    # Simple sanitization
    name=$(echo "$name" | tr -dc '[:alnum:]-_')
    
    run_jq --arg n "$name" --arg c "$cmd" --arg cat "$cat" \
       '.commands += [{"name": $n, "cmd": $c, "category": $cat}]'
}

delete_cmd() {
    local name="${1:-}"
    if [[ -z "$name" ]]; then
        echo "Error: Missing name to delete." >&2
        exit 1
    fi
    
    run_jq --arg n "$name" '.commands |= map(select(.name != $n))'
}

search_cmd() {
    local query="$1"
    jq -r \
        --arg q "${query,,}" \
        --arg bold "$BOLD" \
        --arg dim "$DIM" \
        --arg cyan "$CYAN" \
        --arg green "$GREEN" \
        --arg yellow "$YELLOW" \
        --arg reset "$RESET" \
        '
        def haystack:
          [
            .name,
            .cmd,
            .category,
            .description,
            .notes,
            ((.tags // []) | join(" "))
          ] | map(. // "") | join(" ") | ascii_downcase;
        def tags:
          if (.tags // []) | length > 0 then
            " " + $dim + "#" + ((.tags // []) | join(" #")) + $reset
          else "" end;
        def notes:
          if (.notes // "") != "" then
            "\n    " + $dim + "Note: " + .notes + $reset
          else "" end;
        [
          .commands[]
          | select(haystack | contains($q))
        ] as $matches
        | if ($matches | length) == 0 then
            $dim + "No matches for " + $reset + $yellow + $q + $reset
          else
            $matches
            | sort_by(.category // "general", .name // "")
            | .[]
            | $bold + $green + (.name // "unnamed") + $reset +
              " " + $dim + "[" + (.category // "general") + "]" + $reset + tags + "\n" +
              "  " + $cyan + (.cmd // "") + $reset +
              (if (.description // "") != "" then "\n  " + .description else "" end) +
              notes
          end
        ' "$DATA"
}

case "${1:-}" in
    -l|--list) list_cmds ;;
    -t|--tree) list_cmds ;;
    -a|--add) add_cmd "${2:-}" "${3:-}" "${4:-general}" ;;
    -d|--delete) delete_cmd "${2:-}" ;;
    -e|--edit) ${EDITOR:-vi} "$DATA" ;;
    -h|--help|help) usage ;;
    *) if [ -n "${1:-}" ]; then search_cmd "$1"; else usage; fi ;;
esac
